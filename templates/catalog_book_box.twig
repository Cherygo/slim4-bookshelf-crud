<style>
    /* Custom style to enforce fixed dimensions */
    .book-card-fixed {
    width: 300px; / Fixed width /
    height: 450px; / Fixed height /
    / Ensure the card layout is column-based for precise height control /
    display: flex;
    flex-direction: column;
    }
    .book-card-image {
    width: 100%;
    height: 300px; / Fixed image height for a square look /
    object-fit: cover; / Ensures image covers the space without distortion /
    }
    .card-title-container {
    height: 3rem; / Fixed height for 2 lines of text (approx 1.5rem per line) /
    overflow: hidden; / Hides text that goes beyond the height limit /
    }
    .card-title {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
    }
    .card-author {
    margin-top: 10px; / 10px gap requirement /
    font-size: 0.9rem;
    }
    .card-isbn {
    font-size: 0.75rem; / Smaller font size for ISBN /
    margin-right: 10px; / Separator gap /
    white-space: nowrap; / Prevents ISBN from wrapping if space is tight */
    }
</style>

{# This wrapper div needs to have its width defined in the containing row #}
{#<p>Book ID: {{ book.id }}</p>#}
<div class="col-auto mb-4">
    <div class="card book-card-fixed shadow-sm border-0">

        <img src="{{ book.cover_image_url | default('https://placehold.co/300x300/eeeeee/aaaaaa?text=No+Cover') }}"
             class="card-img-top book-card-image"
             alt="{{ book.title }}">

        <div class="card-body d-flex flex-column p-3">

            <div class="card-title-container">
                <h5 class="card-title">{{ book.title }}</h5>
            </div>

            <p class="card-author text-muted mb-auto">{{ book.author }}</p>
        </div>

        {# Footer: Use flexbox (d-flex) to align items on one line #}
        <div class="card-footer bg-white border-top-0 p-3 d-flex justify-content-between align-items-center">

            {# ISBN (Smaller font) #}
            <small class="text-muted card-isbn">
                ISBN: {{ book.isbn }}
            </small>

            {# Bookmark Button Logic #}
            {% if book.is_bookmarked == 1 %}

                {# UNBOOKMARK FORM #}
                <form action="{{ base_path() }}/bookmark/delete/{{ book.bookmark_id }}" method="POST">

                    {# CRITICAL FIX: Hidden field tells the server where to redirect to #}
                    <input type="hidden" name="redirect_to" value="{{ base_path() }}{{ current_path }}">

                    <button type="submit" class="btn btn-xs btn-danger">
                        <i class="fas fa-heart"></i> Bookmarked
                    </button>
                </form>

            {% else %}

                {# BOOKMARK FORM #}
                <form action="{{ base_path() }}/bookmark/add/{{ book.id }}" method="POST">

                    {# CRITICAL FIX: Hidden field tells the server where to redirect to #}
                    <input type="hidden" name="redirect_to" value="{{ base_path() }}{{ current_path }}">

                    <button type="submit" class="btn btn-xs btn-outline-danger">
                        <i class="far fa-heart"></i> Bookmark
                    </button>
                </form>

            {% endif %}

        </div>
    </div>


</div>