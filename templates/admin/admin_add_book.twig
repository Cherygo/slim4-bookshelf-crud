{% extends 'layout.twig' %}

{% block content %}

    <div class="container mt-5">
        <h1 class="mb-4">Add New Book to Catalog</h1>
        <p class="lead text-muted">Enter the details for the book. ISBN will be used for catalog lookups later.</p>

        <div class="card shadow-lg">
            <div class="card-body">

                <form action="{{ base_path() }}/admin/admin_add_book" method="POST">

                    <div class="mb-3">
                        <label for="title" class="form-label">Title <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="title" name="title" required>
                    </div>

                    <div class="mb-3">
                        <label for="author" class="form-label">Author <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="author" name="author" required>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="isbn" class="form-label">ISBN-13 (Required for lookups)</label>
                            <input type="text" class="form-control" id="isbn" name="isbn">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="publish_date" class="form-label">Publish Date (YYYY-MM-DD)</label>
                            <input type="text" class="form-control" id="publish_date" name="publish_date">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="cover_image_url" class="form-label">Cover Image URL</label>
                        <input type="url" class="form-control" id="cover_image_url" name="cover_image_url">
                        <div class="form-text">Optional. Provide a direct link to the cover image (e.g., JPEG or PNG).</div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-between">
                        <a href="{{ base_path() }}/admin/admin_books" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left me-2"></i> Back to List
                        </a>
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-save me-2"></i> Save Book
                        </button>
                    </div>
                </form>

            </div>
        </div>


    </div>
{% endblock %}